    "main": "@astrojs/cloudflare/entrypoints/server",
    "route": {
        "pattern": "ip.lorypelli.dev",
        "custom_domain": true
    },
    "assets": {
        "binding": "ASSETS",
        "directory": "./dist"
    }
}
